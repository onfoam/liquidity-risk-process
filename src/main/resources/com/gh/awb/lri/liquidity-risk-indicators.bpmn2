<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:tns="http://www.jboss.org/drools"
    id="_lri_definitions" targetNamespace="http://www.jboss.org/drools"
    exporter="jBPM Process Modeler" exporterVersion="2.0">

  <bpmn2:itemDefinition id="_intItem" structureRef="Integer"/>
  <bpmn2:itemDefinition id="_strItem" structureRef="String"/>
  <bpmn2:itemDefinition id="_dblItem" structureRef="Double"/>
  <bpmn2:itemDefinition id="_boolItem" structureRef="Boolean"/>
  <bpmn2:itemDefinition id="_listItem" structureRef="java.util.List"/>

  <bpmn2:process id="com.gh.awb.lri.LiquidityRiskIndicators"
      name="Liquidity Risk Indicators" isExecutable="true"
      processType="Private" tns:packageName="com.gh.awb.lri">

    <!-- ═══ PROCESS VARIABLES ═══ -->
    <bpmn2:property id="selectedYear" itemSubjectRef="_intItem" name="selectedYear"/>
    <bpmn2:property id="selectedQuarterRange" itemSubjectRef="_strItem" name="selectedQuarterRange"/>
    <bpmn2:property id="lcrQA" itemSubjectRef="_dblItem" name="lcrQA"/>
    <bpmn2:property id="lcrQB" itemSubjectRef="_dblItem" name="lcrQB"/>
    <bpmn2:property id="lcrCoverage" itemSubjectRef="_dblItem" name="lcrCoverage"/>
    <bpmn2:property id="nsfrQA" itemSubjectRef="_dblItem" name="nsfrQA"/>
    <bpmn2:property id="nsfrQB" itemSubjectRef="_dblItem" name="nsfrQB"/>
    <bpmn2:property id="nsfrCoverage" itemSubjectRef="_dblItem" name="nsfrCoverage"/>
    <bpmn2:property id="leverageQA" itemSubjectRef="_dblItem" name="leverageQA"/>
    <bpmn2:property id="leverageQB" itemSubjectRef="_dblItem" name="leverageQB"/>
    <bpmn2:property id="leverageCoverage" itemSubjectRef="_dblItem" name="leverageCoverage"/>
    <bpmn2:property id="employeeComment" itemSubjectRef="_strItem" name="employeeComment"/>
    <bpmn2:property id="managerComment" itemSubjectRef="_strItem" name="managerComment"/>
    <bpmn2:property id="returnComment" itemSubjectRef="_strItem" name="returnComment"/>
    <bpmn2:property id="makerAction" itemSubjectRef="_strItem" name="makerAction"/>
    <bpmn2:property id="managerAction" itemSubjectRef="_strItem" name="managerAction"/>
    <bpmn2:property id="reportStatus" itemSubjectRef="_strItem" name="reportStatus"/>
    <bpmn2:property id="isReturned" itemSubjectRef="_boolItem" name="isReturned"/>
    <bpmn2:property id="dataAvailable" itemSubjectRef="_boolItem" name="dataAvailable"/>
    <bpmn2:property id="calcWarnings" itemSubjectRef="_listItem" name="calcWarnings"/>

    <!-- ═══ START ═══ -->
    <bpmn2:startEvent id="_start" name="Start">
      <bpmn2:outgoing>_sf_start_ht01</bpmn2:outgoing>
    </bpmn2:startEvent>

    <!-- ═══ HT-01: Select Period ═══ -->
    <bpmn2:userTask id="_ht01" name="Select Reporting Period">
      <bpmn2:incoming>_sf_start_ht01</bpmn2:incoming>
      <bpmn2:outgoing>_sf_ht01_st01</bpmn2:outgoing>
      <bpmn2:ioSpecification>
        <bpmn2:dataOutput id="_ht01_year" name="selectedYear"/>
        <bpmn2:dataOutput id="_ht01_qr" name="selectedQuarterRange"/>
        <bpmn2:outputSet><bpmn2:dataOutputRefs>_ht01_year</bpmn2:dataOutputRefs><bpmn2:dataOutputRefs>_ht01_qr</bpmn2:dataOutputRefs></bpmn2:outputSet>
      </bpmn2:ioSpecification>
      <bpmn2:dataOutputAssociation><bpmn2:sourceRef>_ht01_year</bpmn2:sourceRef><bpmn2:targetRef>selectedYear</bpmn2:targetRef></bpmn2:dataOutputAssociation>
      <bpmn2:dataOutputAssociation><bpmn2:sourceRef>_ht01_qr</bpmn2:sourceRef><bpmn2:targetRef>selectedQuarterRange</bpmn2:targetRef></bpmn2:dataOutputAssociation>
      <bpmn2:potentialOwner><bpmn2:resourceAssignmentExpression><bpmn2:formalExpression>lri-maker</bpmn2:formalExpression></bpmn2:resourceAssignmentExpression></bpmn2:potentialOwner>
    </bpmn2:userTask>

    <!-- ═══ ST-01: Validate Data ═══ -->
    <bpmn2:task id="_st01" name="Validate Data Availability" tns:taskName="DataValidation">
      <bpmn2:incoming>_sf_ht01_st01</bpmn2:incoming>
      <bpmn2:outgoing>_sf_st01_gw01</bpmn2:outgoing>
    </bpmn2:task>

    <!-- ═══ GW-01: Data Available? ═══ -->
    <bpmn2:exclusiveGateway id="_gw01" name="Data Available?" gatewayDirection="Diverging" default="_sf_gw01_err">
      <bpmn2:incoming>_sf_st01_gw01</bpmn2:incoming>
      <bpmn2:outgoing>_sf_gw01_st02</bpmn2:outgoing>
      <bpmn2:outgoing>_sf_gw01_err</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>

    <!-- ═══ ST-02: Calculate ═══ -->
    <bpmn2:task id="_st02" name="Calculate Quarterly Indicators" tns:taskName="CalculateIndicators">
      <bpmn2:incoming>_sf_gw01_st02</bpmn2:incoming>
      <bpmn2:outgoing>_sf_st02_ht02</bpmn2:outgoing>
    </bpmn2:task>

    <!-- ═══ HT-02: Review & Comment ═══ -->
    <bpmn2:userTask id="_ht02" name="Review and Comment Indicators">
      <bpmn2:incoming>_sf_st02_ht02</bpmn2:incoming>
      <bpmn2:incoming>_sf_gw02_ht02</bpmn2:incoming>
      <bpmn2:incoming>_sf_gw03_ht02</bpmn2:incoming>
      <bpmn2:outgoing>_sf_ht02_gw02</bpmn2:outgoing>
      <bpmn2:ioSpecification>
        <bpmn2:dataOutput id="_ht02_comment" name="employeeComment"/>
        <bpmn2:dataOutput id="_ht02_action" name="makerAction"/>
        <bpmn2:outputSet><bpmn2:dataOutputRefs>_ht02_comment</bpmn2:dataOutputRefs><bpmn2:dataOutputRefs>_ht02_action</bpmn2:dataOutputRefs></bpmn2:outputSet>
      </bpmn2:ioSpecification>
      <bpmn2:dataOutputAssociation><bpmn2:sourceRef>_ht02_comment</bpmn2:sourceRef><bpmn2:targetRef>employeeComment</bpmn2:targetRef></bpmn2:dataOutputAssociation>
      <bpmn2:dataOutputAssociation><bpmn2:sourceRef>_ht02_action</bpmn2:sourceRef><bpmn2:targetRef>makerAction</bpmn2:targetRef></bpmn2:dataOutputAssociation>
      <bpmn2:potentialOwner><bpmn2:resourceAssignmentExpression><bpmn2:formalExpression>lri-maker</bpmn2:formalExpression></bpmn2:resourceAssignmentExpression></bpmn2:potentialOwner>
    </bpmn2:userTask>

    <!-- ═══ GW-02: Maker Action ═══ -->
    <bpmn2:exclusiveGateway id="_gw02" name="Maker Action" gatewayDirection="Diverging" default="_sf_gw02_ht02">
      <bpmn2:incoming>_sf_ht02_gw02</bpmn2:incoming>
      <bpmn2:outgoing>_sf_gw02_ht03</bpmn2:outgoing>
      <bpmn2:outgoing>_sf_gw02_ht02</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>

    <!-- ═══ HT-03: Manager Review ═══ -->
    <bpmn2:userTask id="_ht03" name="Manager Review">
      <bpmn2:incoming>_sf_gw02_ht03</bpmn2:incoming>
      <bpmn2:outgoing>_sf_ht03_gw03</bpmn2:outgoing>
      <bpmn2:ioSpecification>
        <bpmn2:dataOutput id="_ht03_mc" name="managerComment"/>
        <bpmn2:dataOutput id="_ht03_ma" name="managerAction"/>
        <bpmn2:dataOutput id="_ht03_rc" name="returnComment"/>
        <bpmn2:outputSet/>
      </bpmn2:ioSpecification>
      <bpmn2:dataOutputAssociation><bpmn2:sourceRef>_ht03_mc</bpmn2:sourceRef><bpmn2:targetRef>managerComment</bpmn2:targetRef></bpmn2:dataOutputAssociation>
      <bpmn2:dataOutputAssociation><bpmn2:sourceRef>_ht03_ma</bpmn2:sourceRef><bpmn2:targetRef>managerAction</bpmn2:targetRef></bpmn2:dataOutputAssociation>
      <bpmn2:dataOutputAssociation><bpmn2:sourceRef>_ht03_rc</bpmn2:sourceRef><bpmn2:targetRef>returnComment</bpmn2:targetRef></bpmn2:dataOutputAssociation>
      <bpmn2:potentialOwner><bpmn2:resourceAssignmentExpression><bpmn2:formalExpression>lri-checker</bpmn2:formalExpression></bpmn2:resourceAssignmentExpression></bpmn2:potentialOwner>
    </bpmn2:userTask>

    <!-- Timers on HT-03 -->
    <bpmn2:boundaryEvent id="_timer_ht03_3d" name="3d Reminder" attachedToRef="_ht03" cancelActivity="false">
      <bpmn2:outgoing>_sf_t3d</bpmn2:outgoing>
      <bpmn2:timerEventDefinition><bpmn2:timeDuration xsi:type="bpmn2:tFormalExpression">P3D</bpmn2:timeDuration></bpmn2:timerEventDefinition>
    </bpmn2:boundaryEvent>
    <bpmn2:boundaryEvent id="_timer_ht03_10d" name="10d Escalation" attachedToRef="_ht03" cancelActivity="false">
      <bpmn2:outgoing>_sf_t10d</bpmn2:outgoing>
      <bpmn2:timerEventDefinition><bpmn2:timeDuration xsi:type="bpmn2:tFormalExpression">P10D</bpmn2:timeDuration></bpmn2:timerEventDefinition>
    </bpmn2:boundaryEvent>
    <bpmn2:task id="_ntf_remind" name="Send Reminder" tns:taskName="SendNotification"><bpmn2:incoming>_sf_t3d</bpmn2:incoming></bpmn2:task>
    <bpmn2:task id="_ntf_escalate" name="Send Escalation" tns:taskName="SendNotification"><bpmn2:incoming>_sf_t10d</bpmn2:incoming></bpmn2:task>

    <!-- ═══ GW-03: Manager Decision ═══ -->
    <bpmn2:exclusiveGateway id="_gw03" name="Manager Decision" gatewayDirection="Diverging" default="_sf_gw03_ht02">
      <bpmn2:incoming>_sf_ht03_gw03</bpmn2:incoming>
      <bpmn2:outgoing>_sf_gw03_ht04</bpmn2:outgoing>
      <bpmn2:outgoing>_sf_gw03_ht02</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>

    <!-- ═══ HT-04: Director Approval ═══ -->
    <bpmn2:userTask id="_ht04" name="Director Final Approval">
      <bpmn2:incoming>_sf_gw03_ht04</bpmn2:incoming>
      <bpmn2:outgoing>_sf_ht04_st04</bpmn2:outgoing>
      <bpmn2:potentialOwner><bpmn2:resourceAssignmentExpression><bpmn2:formalExpression>lri-approver</bpmn2:formalExpression></bpmn2:resourceAssignmentExpression></bpmn2:potentialOwner>
    </bpmn2:userTask>

    <!-- Timer on HT-04 -->
    <bpmn2:boundaryEvent id="_timer_ht04_3d" name="Dir 3d Reminder" attachedToRef="_ht04" cancelActivity="false">
      <bpmn2:outgoing>_sf_tdir3d</bpmn2:outgoing>
      <bpmn2:timerEventDefinition><bpmn2:timeDuration xsi:type="bpmn2:tFormalExpression">P3D</bpmn2:timeDuration></bpmn2:timerEventDefinition>
    </bpmn2:boundaryEvent>
    <bpmn2:task id="_ntf_dir" name="Send Dir Reminder" tns:taskName="SendNotification"><bpmn2:incoming>_sf_tdir3d</bpmn2:incoming></bpmn2:task>

    <!-- ═══ ST-04: Archive ═══ -->
    <bpmn2:task id="_st04" name="Archive Final Report" tns:taskName="ArchiveReport">
      <bpmn2:incoming>_sf_ht04_st04</bpmn2:incoming>
      <bpmn2:outgoing>_sf_st04_end</bpmn2:outgoing>
    </bpmn2:task>

    <!-- ═══ END EVENTS ═══ -->
    <bpmn2:endEvent id="_end" name="Complete"><bpmn2:incoming>_sf_st04_end</bpmn2:incoming></bpmn2:endEvent>
    <bpmn2:endEvent id="_errEnd01" name="No Data Error"><bpmn2:incoming>_sf_gw01_err</bpmn2:incoming><bpmn2:errorEventDefinition errorRef="DataNotAvailable"/></bpmn2:endEvent>

    <!-- ═══ SEQUENCE FLOWS ═══ -->
    <bpmn2:sequenceFlow id="_sf_start_ht01" sourceRef="_start" targetRef="_ht01"/>
    <bpmn2:sequenceFlow id="_sf_ht01_st01" sourceRef="_ht01" targetRef="_st01"/>
    <bpmn2:sequenceFlow id="_sf_st01_gw01" sourceRef="_st01" targetRef="_gw01"/>
    <bpmn2:sequenceFlow id="_sf_gw01_st02" sourceRef="_gw01" targetRef="_st02" name="Yes">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return dataAvailable == true;</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="_sf_gw01_err" sourceRef="_gw01" targetRef="_errEnd01" name="No"/>
    <bpmn2:sequenceFlow id="_sf_st02_ht02" sourceRef="_st02" targetRef="_ht02"/>
    <bpmn2:sequenceFlow id="_sf_ht02_gw02" sourceRef="_ht02" targetRef="_gw02"/>
    <bpmn2:sequenceFlow id="_sf_gw02_ht03" sourceRef="_gw02" targetRef="_ht03" name="Submit">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return "submit".equals(makerAction);</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="_sf_gw02_ht02" sourceRef="_gw02" targetRef="_ht02" name="Save"/>
    <bpmn2:sequenceFlow id="_sf_ht03_gw03" sourceRef="_ht03" targetRef="_gw03"/>
    <bpmn2:sequenceFlow id="_sf_gw03_ht04" sourceRef="_gw03" targetRef="_ht04" name="Submit">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return "submit".equals(managerAction);</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="_sf_gw03_ht02" sourceRef="_gw03" targetRef="_ht02" name="Return">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return "return".equals(managerAction);</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="_sf_ht04_st04" sourceRef="_ht04" targetRef="_st04"/>
    <bpmn2:sequenceFlow id="_sf_st04_end" sourceRef="_st04" targetRef="_end"/>
    <bpmn2:sequenceFlow id="_sf_t3d" sourceRef="_timer_ht03_3d" targetRef="_ntf_remind"/>
    <bpmn2:sequenceFlow id="_sf_t10d" sourceRef="_timer_ht03_10d" targetRef="_ntf_escalate"/>
    <bpmn2:sequenceFlow id="_sf_tdir3d" sourceRef="_timer_ht04_3d" targetRef="_ntf_dir"/>
  </bpmn2:process>

  <bpmn2:error id="DataNotAvailable" errorCode="ERR_NO_DATA" name="Data Not Available"/>

  <!-- ═══════════════════════════════════════════ -->
  <!-- BPMN DIAGRAM INTERCHANGE (Visual Layout)   -->
  <!-- ═══════════════════════════════════════════ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="com.gh.awb.lri.LiquidityRiskIndicators">

      <!-- Start -->
      <bpmndi:BPMNShape id="_start_di" bpmnElement="_start"><dc:Bounds x="60" y="240" width="36" height="36"/></bpmndi:BPMNShape>
      <!-- HT-01 -->
      <bpmndi:BPMNShape id="_ht01_di" bpmnElement="_ht01"><dc:Bounds x="160" y="218" width="160" height="80"/></bpmndi:BPMNShape>
      <!-- ST-01 -->
      <bpmndi:BPMNShape id="_st01_di" bpmnElement="_st01"><dc:Bounds x="390" y="218" width="160" height="80"/></bpmndi:BPMNShape>
      <!-- GW-01 -->
      <bpmndi:BPMNShape id="_gw01_di" bpmnElement="_gw01" isMarkerVisible="true"><dc:Bounds x="620" y="233" width="50" height="50"/></bpmndi:BPMNShape>
      <!-- Error End -->
      <bpmndi:BPMNShape id="_errEnd01_di" bpmnElement="_errEnd01"><dc:Bounds x="627" y="370" width="36" height="36"/></bpmndi:BPMNShape>
      <!-- ST-02 -->
      <bpmndi:BPMNShape id="_st02_di" bpmnElement="_st02"><dc:Bounds x="740" y="218" width="160" height="80"/></bpmndi:BPMNShape>
      <!-- HT-02 -->
      <bpmndi:BPMNShape id="_ht02_di" bpmnElement="_ht02"><dc:Bounds x="970" y="218" width="160" height="80"/></bpmndi:BPMNShape>
      <!-- GW-02 -->
      <bpmndi:BPMNShape id="_gw02_di" bpmnElement="_gw02" isMarkerVisible="true"><dc:Bounds x="1200" y="233" width="50" height="50"/></bpmndi:BPMNShape>
      <!-- HT-03 -->
      <bpmndi:BPMNShape id="_ht03_di" bpmnElement="_ht03"><dc:Bounds x="1320" y="218" width="160" height="80"/></bpmndi:BPMNShape>
      <!-- Timer 3d on HT-03 -->
      <bpmndi:BPMNShape id="_timer_ht03_3d_di" bpmnElement="_timer_ht03_3d"><dc:Bounds x="1340" y="282" width="36" height="36"/></bpmndi:BPMNShape>
      <!-- Timer 10d on HT-03 -->
      <bpmndi:BPMNShape id="_timer_ht03_10d_di" bpmnElement="_timer_ht03_10d"><dc:Bounds x="1420" y="282" width="36" height="36"/></bpmndi:BPMNShape>
      <!-- Notification: Reminder -->
      <bpmndi:BPMNShape id="_ntf_remind_di" bpmnElement="_ntf_remind"><dc:Bounds x="1298" y="370" width="120" height="60"/></bpmndi:BPMNShape>
      <!-- Notification: Escalation -->
      <bpmndi:BPMNShape id="_ntf_escalate_di" bpmnElement="_ntf_escalate"><dc:Bounds x="1438" y="370" width="120" height="60"/></bpmndi:BPMNShape>
      <!-- GW-03 -->
      <bpmndi:BPMNShape id="_gw03_di" bpmnElement="_gw03" isMarkerVisible="true"><dc:Bounds x="1550" y="233" width="50" height="50"/></bpmndi:BPMNShape>
      <!-- HT-04 -->
      <bpmndi:BPMNShape id="_ht04_di" bpmnElement="_ht04"><dc:Bounds x="1670" y="218" width="160" height="80"/></bpmndi:BPMNShape>
      <!-- Timer on HT-04 -->
      <bpmndi:BPMNShape id="_timer_ht04_3d_di" bpmnElement="_timer_ht04_3d"><dc:Bounds x="1730" y="282" width="36" height="36"/></bpmndi:BPMNShape>
      <!-- Dir Reminder -->
      <bpmndi:BPMNShape id="_ntf_dir_di" bpmnElement="_ntf_dir"><dc:Bounds x="1688" y="370" width="120" height="60"/></bpmndi:BPMNShape>
      <!-- ST-04 -->
      <bpmndi:BPMNShape id="_st04_di" bpmnElement="_st04"><dc:Bounds x="1900" y="218" width="160" height="80"/></bpmndi:BPMNShape>
      <!-- End -->
      <bpmndi:BPMNShape id="_end_di" bpmnElement="_end"><dc:Bounds x="2130" y="240" width="36" height="36"/></bpmndi:BPMNShape>

      <!-- ═══ EDGES ═══ -->
      <bpmndi:BPMNEdge id="_sf_start_ht01_di" bpmnElement="_sf_start_ht01"><di:waypoint x="96" y="258"/><di:waypoint x="160" y="258"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="_sf_ht01_st01_di" bpmnElement="_sf_ht01_st01"><di:waypoint x="320" y="258"/><di:waypoint x="390" y="258"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="_sf_st01_gw01_di" bpmnElement="_sf_st01_gw01"><di:waypoint x="550" y="258"/><di:waypoint x="620" y="258"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="_sf_gw01_st02_di" bpmnElement="_sf_gw01_st02"><di:waypoint x="670" y="258"/><di:waypoint x="740" y="258"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="_sf_gw01_err_di" bpmnElement="_sf_gw01_err"><di:waypoint x="645" y="283"/><di:waypoint x="645" y="370"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="_sf_st02_ht02_di" bpmnElement="_sf_st02_ht02"><di:waypoint x="900" y="258"/><di:waypoint x="970" y="258"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="_sf_ht02_gw02_di" bpmnElement="_sf_ht02_gw02"><di:waypoint x="1130" y="258"/><di:waypoint x="1200" y="258"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="_sf_gw02_ht03_di" bpmnElement="_sf_gw02_ht03"><di:waypoint x="1250" y="258"/><di:waypoint x="1320" y="258"/></bpmndi:BPMNEdge>
      <!-- Save loop: GW-02 back to HT-02 -->
      <bpmndi:BPMNEdge id="_sf_gw02_ht02_di" bpmnElement="_sf_gw02_ht02"><di:waypoint x="1225" y="233"/><di:waypoint x="1225" y="160"/><di:waypoint x="1050" y="160"/><di:waypoint x="1050" y="218"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="_sf_ht03_gw03_di" bpmnElement="_sf_ht03_gw03"><di:waypoint x="1480" y="258"/><di:waypoint x="1550" y="258"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="_sf_gw03_ht04_di" bpmnElement="_sf_gw03_ht04"><di:waypoint x="1600" y="258"/><di:waypoint x="1670" y="258"/></bpmndi:BPMNEdge>
      <!-- Return loop: GW-03 back to HT-02 -->
      <bpmndi:BPMNEdge id="_sf_gw03_ht02_di" bpmnElement="_sf_gw03_ht02"><di:waypoint x="1575" y="233"/><di:waypoint x="1575" y="100"/><di:waypoint x="1050" y="100"/><di:waypoint x="1050" y="218"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="_sf_ht04_st04_di" bpmnElement="_sf_ht04_st04"><di:waypoint x="1830" y="258"/><di:waypoint x="1900" y="258"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="_sf_st04_end_di" bpmnElement="_sf_st04_end"><di:waypoint x="2060" y="258"/><di:waypoint x="2130" y="258"/></bpmndi:BPMNEdge>
      <!-- Timer edges -->
      <bpmndi:BPMNEdge id="_sf_t3d_di" bpmnElement="_sf_t3d"><di:waypoint x="1358" y="318"/><di:waypoint x="1358" y="370"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="_sf_t10d_di" bpmnElement="_sf_t10d"><di:waypoint x="1438" y="318"/><di:waypoint x="1498" y="370"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="_sf_tdir3d_di" bpmnElement="_sf_tdir3d"><di:waypoint x="1748" y="318"/><di:waypoint x="1748" y="370"/></bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn2:definitions>
