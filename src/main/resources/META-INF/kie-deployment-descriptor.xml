<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<deployment-descriptor xsi:schemaLocation="http://www.jboss.org/jbpm deployment-descriptor.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <persistence-unit>com.gh.awb.lri</persistence-unit>
    <audit-persistence-unit>com.gh.awb.lri</audit-persistence-unit>
    <audit-mode>JPA</audit-mode>
    <persistence-mode>JPA</persistence-mode>
    <runtime-strategy>PER_PROCESS_INSTANCE</runtime-strategy>
    <work-item-handlers>
        <work-item-handler><resolver>mvel</resolver><identifier>new com.gh.awb.lri.handler.DataValidationHandler(runtimeManager)</identifier><parameters/><name>DataValidation</name></work-item-handler>
        <work-item-handler><resolver>mvel</resolver><identifier>new com.gh.awb.lri.handler.CalculationHandler(runtimeManager)</identifier><parameters/><name>CalculateIndicators</name></work-item-handler>
        <work-item-handler><resolver>mvel</resolver><identifier>new com.gh.awb.lri.handler.ArchiveReportHandler(runtimeManager)</identifier><parameters/><name>ArchiveReport</name></work-item-handler>
        <work-item-handler><resolver>mvel</resolver><identifier>new com.gh.awb.lri.handler.ReportGenerationHandler(runtimeManager)</identifier><parameters/><name>GenerateReport</name></work-item-handler>
        <work-item-handler><resolver>mvel</resolver><identifier>new com.gh.awb.lri.handler.NotificationHandler(runtimeManager)</identifier><parameters/><name>SendNotification</name></work-item-handler>
    </work-item-handlers>
</deployment-descriptor>
