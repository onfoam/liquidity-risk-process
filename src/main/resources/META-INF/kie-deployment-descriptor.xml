<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<deployment-descriptor 
    xsi:schemaLocation="http://www.jboss.org/jbpm deployment-descriptor.xsd" 
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <persistence-unit>com.gh.awb.lri</persistence-unit>
    <audit-persistence-unit>com.gh.awb.lri</audit-persistence-unit>
    <audit-mode>JPA</audit-mode>
    <persistence-mode>JPA</persistence-mode>
    <runtime-strategy>PER_PROCESS_INSTANCE</runtime-strategy>
    <work-item-handlers>
        <work-item-handler>
            <resolver>mvel</resolver>
            <identifier>new com.gh.awb.handler.ValidateDataHandler(runtimeManager)</identifier>
            <parameters/>
            <name>ValidateData</name>
        </work-item-handler>
        <work-item-handler>
            <resolver>mvel</resolver>
            <identifier>new com.gh.awb.handler.CalculateIndicatorsHandler(runtimeManager)</identifier>
            <parameters/>
            <name>CalculateIndicators</name>
        </work-item-handler>
        <work-item-handler>
            <resolver>mvel</resolver>
            <identifier>new com.gh.awb.handler.ArchiveReportHandler(runtimeManager)</identifier>
            <parameters/>
            <name>ArchiveReport</name>
        </work-item-handler>
    </work-item-handlers>
</deployment-descriptor>
